# ----------------------------------------------------------------------------
# Agent gateway -- printed by `npm run deploy`. Server-only (never
# NEXT_PUBLIC_*) so the bearer token never reaches the browser.
# (legacy names HERMES_API_URL / HERMES_API_KEY / HERMES_MODEL still work)
# ----------------------------------------------------------------------------
AGENT_API_URL=https://your-tunnel.trycloudflare.com/v1
AGENT_API_KEY=hp-replace-me
AGENT_MODEL=hermes-agent

# ----------------------------------------------------------------------------
# Dedalus -- the dashboard reads machine state via the controlplane REST API.
# `DEDALUS_API_KEY` is the same key that provisions machines (see root .env).
# `AGENT_MACHINE_ID` is printed by `npm run deploy` (also in .machine-state.json).
# (legacy name HERMES_MACHINE_ID still works)
# ----------------------------------------------------------------------------
DEDALUS_API_KEY=dsk-live-replace-me
DEDALUS_BASE_URL=https://dcs.dedaluslabs.ai
AGENT_MACHINE_ID=dm-replace-me

# ----------------------------------------------------------------------------
# Clerk -- gates /dashboard/* and /api/dashboard/*. Configure the email
# allowlist under "User & Authentication -> Restrictions" in the Clerk
# dashboard. Both keys come from https://dashboard.clerk.com -> API Keys.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# ----------------------------------------------------------------------------
# Local dev auth bypass. When this is `1` AND `NODE_ENV=development`, every
# protected route (/dashboard, /api/dashboard, /api/chat) is treated as
# signed in under a synthetic `dev-user` identity. The user-config layer
# routes reads/writes to `web/.dev-user-config.json` instead of Clerk
# metadata, so the dashboard works end-to-end without anyone signing in.
# Production / preview deploys ignore this flag because NODE_ENV != dev.
# ----------------------------------------------------------------------------
ALLOW_DEV_AUTH=0

# ----------------------------------------------------------------------------
# Supabase -- machine configs, metrics, usage, and cost data. The service
# role key is server-only; the anon key is safe for the browser but we only
# use it if we add client-side realtime later.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://ytlflfdpmpehrdsaylcp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace-me
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace-me
